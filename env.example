# FinancialProof - lokale Beispielkonfiguration
# Kopiere diese Datei nach .env, falls du lokale Umgebungsvariablen nutzen willst.
# Windows PowerShell: Copy-Item env.example .env
# Bash: cp env.example .env
#
# Wichtig: .env, data/.key, data/.secrets und lokale Datenbanken dürfen nicht
# committed werden. API-Keys werden in der App über die Sidebar gespeichert.

# ===== Logging =====

# Log Level (DEBUG, INFO, WARNING, ERROR)
FINANCIALPROOF_LOG_LEVEL=INFO
